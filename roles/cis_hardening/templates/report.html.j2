<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CIS Hardening Report — {{ ansible_facts['hostname'] }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --border:   #30363d;
      --text:     #c9d1d9;
      --muted:    #8b949e;
      --accent:   #58a6ff;
      --green:    #3fb950;
      --red:      #f85149;
      --yellow:   #d29922;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    .container {
      max-width: 960px;
      margin: 0 auto;
    }

    /* ── Header ── */
    header {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }

    .badge {
      display: inline-block;
      background: #1f2937;
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2px 12px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    header h1 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #e6edf3;
      margin-bottom: 1.5rem;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
    }

    .meta-item label {
      display: block;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      margin-bottom: 2px;
    }

    .meta-item span {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: var(--text);
    }

    /* ── Score Cards ── */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      text-align: center;
    }

    .card-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }

    .card-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 2rem;
      font-weight: 700;
      line-height: 1;
    }

    .card-value.green  { color: var(--green); }
    .card-value.red    { color: var(--red); }
    .card-value.score  { color: {% if compliance_pct | float >= 80 %}var(--green){% elif compliance_pct | float >= 60 %}var(--yellow){% else %}var(--red){% endif %}; }
    .card-value.neutral{ color: var(--accent); }

    /* ── Progress Bar ── */
    .progress-section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
    }

    .progress-header span {
      font-size: 13px;
      color: var(--muted);
    }

    .progress-bar-track {
      background: var(--border);
      border-radius: 4px;
      height: 10px;
      overflow: hidden;
      margin-bottom: 1rem;
    }

    .progress-bar-fill {
      height: 100%;
      border-radius: 4px;
      width: {{ compliance_pct }}%;
      background: {% if compliance_pct | float >= 80 %}var(--green){% elif compliance_pct | float >= 60 %}var(--yellow){% else %}var(--red){% endif %};
      transition: width 0.6s ease;
    }

    .status-badge {
      display: inline-block;
      border-radius: 20px;
      padding: 4px 16px;
      font-size: 13px;
      font-weight: 600;
      {% if compliance_pct | float >= 80 %}
      background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid var(--green);
      {% elif compliance_pct | float >= 60 %}
      background: rgba(210,153,34,0.15); color: var(--yellow); border: 1px solid var(--yellow);
      {% else %}
      background: rgba(248,81,73,0.15); color: var(--red); border: 1px solid var(--red);
      {% endif %}
    }

    /* ── Results Table ── */
    .results-section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .results-section h2 {
      font-size: 14px;
      font-weight: 600;
      color: #e6edf3;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      background: #0d1117;
      text-align: left;
      padding: 0.6rem 1.5rem;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }

    tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.1s;
    }

    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(255,255,255,0.02); }

    td {
      padding: 0.75rem 1.5rem;
      vertical-align: middle;
    }

    .cis-id {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--accent);
      white-space: nowrap;
    }

    .chip {
      display: inline-block;
      border-radius: 4px;
      padding: 2px 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
    }

    .chip-pass { background: rgba(63,185,80,0.15);  color: var(--green); }
    .chip-fail { background: rgba(248,81,73,0.15);   color: var(--red); }

    /* ── Footer ── */
    footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: 12px;
      padding-top: 0.5rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    footer span { font-family: 'JetBrains Mono', monospace; }
  </style>
</head>
<body>
  <div class="container">

    <!-- Header -->
    <header>
      <div class="badge">CIS BENCHMARK · LEVEL 1</div>
      <h1>Linux Hardening Report</h1>
      <div class="meta-grid">
        <div class="meta-item">
          <label>Hostname</label>
          <span>{{ ansible_facts['hostname'] }}</span>
        </div>
        <div class="meta-item">
          <label>IP Address</label>
          <span>{{ ansible_facts['default_ipv4']['address'] | default('N/A') }}</span>
        </div>
        <div class="meta-item">
          <label>Operating System</label>
          <span>{{ ansible_facts['distribution'] }} {{ ansible_facts['distribution_version'] }}</span>
        </div>
        <div class="meta-item">
          <label>Kernel</label>
          <span>{{ ansible_facts['kernel'] }}</span>
        </div>
        <div class="meta-item">
          <label>Report Date</label>
          <span>{{ ansible_facts['date_time']['iso8601'] }}</span>
        </div>
      </div>
    </header>

    <!-- Score Cards -->
    <div class="cards">
      <div class="card">
        <div class="card-label">Total Checks</div>
        <div class="card-value neutral">{{ total_count }}</div>
      </div>
      <div class="card">
        <div class="card-label">Passed</div>
        <div class="card-value green">{{ pass_count }}</div>
      </div>
      <div class="card">
        <div class="card-label">Failed</div>
        <div class="card-value red">{{ fail_count }}</div>
      </div>
      <div class="card">
        <div class="card-label">Compliance Score</div>
        <div class="card-value score">{{ compliance_pct }}%</div>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="progress-section">
      <div class="progress-header">
        <span>Compliance Progress</span>
        <span>{{ pass_count }} / {{ total_count }} controls passed</span>
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill"></div>
      </div>
      <span class="status-badge">
        {% if compliance_pct | float >= 80 %}✔ COMPLIANT{% elif compliance_pct | float >= 60 %}⚠ PARTIALLY COMPLIANT — remediation required{% else %}✘ NON-COMPLIANT — immediate action required{% endif %}
      </span>
    </div>

    <!-- Detailed Results Table -->
    <div class="results-section">
      <h2>Detailed Results</h2>
      <table>
        <thead>
          <tr>
            <th>Control ID</th>
            <th>Description</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {% for result in compliance_results %}
          <tr>
            <td class="cis-id">{{ result.id }}</td>
            <td>{{ result.title }}</td>
            <td>
              {% if result.status == 'PASS' %}
              <span class="chip chip-pass">PASS</span>
              {% else %}
              <span class="chip chip-fail">FAIL</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <!-- Footer -->
    <footer>
      <span>ansible-linux-hardening · fo:sabatino · fo:platform-engineering</span>
      <span>{{ ansible_facts['date_time']['iso8601'] }}</span>
    </footer>

  </div>
</body>
</html>
